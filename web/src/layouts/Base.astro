---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Mes recettes en Cooklang" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="alternate icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <meta name="theme-color" content="#D85A30" />
    <title>{title}</title>
    <script is:inline>
      try {
        const saved = localStorage.getItem("theme");
        if (saved === "dark" || saved === "light") {
          document.documentElement.dataset.theme = saved;
        }
      } catch {}
    </script>
  </head>
  <body>
    <button
      id="theme-toggle"
      type="button"
      class="theme-toggle"
      aria-label="Basculer le thème clair/sombre"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
    </button>
    <slot />

    <aside class="timer-tray" aria-label="Timers en cours" hidden>
      <ul class="timer-list"></ul>
    </aside>

    <script>
      import {
        addTimer,
        isExpired,
        remainingSeconds,
        removeTimer,
        type Timer,
      } from "../lib/timers";
      import { formatSecondsAsTime } from "../lib/cuisson";

      const STORAGE_KEY = "active-timers";

      function readTimers(): Timer[] {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]");
        } catch {
          return [];
        }
      }
      function writeTimers(timers: Timer[]): void {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(timers));
      }

      const tray = document.querySelector<HTMLElement>(".timer-tray");
      const list = tray?.querySelector<HTMLElement>(".timer-list");

      const beep = new Audio(
        import.meta.env.BASE_URL + "audio/timer-beep.mp3",
      );
      const notified = new Set<string>();
      // Ne pas sonner pour les timers déjà expirés au chargement (session précédente).
      readTimers().forEach((t) => {
        if (isExpired(t, Date.now())) notified.add(t.id);
      });

      function render() {
        if (!tray || !list) return;
        const timers = readTimers();
        if (timers.length === 0) {
          tray.hidden = true;
          list.replaceChildren();
          return;
        }
        tray.hidden = false;
        const now = Date.now();
        // Détecter les transitions running → expired pour notifier une fois.
        timers.forEach((t) => {
          if (isExpired(t, now) && !notified.has(t.id)) {
            notified.add(t.id);
            beep.currentTime = 0;
            beep.play().catch(() => {});
          }
        });
        list.replaceChildren(
          ...timers.map((t) => {
            const li = document.createElement("li");
            li.className = "timer-item";
            li.dataset.timerId = t.id;
            if (isExpired(t, now)) li.classList.add("is-expired");
            const name = document.createElement("div");
            name.className = "timer-name";
            name.textContent = t.name;
            const rem = document.createElement("div");
            rem.className = "timer-remaining";
            rem.textContent = formatSecondsAsTime(
              Math.max(0, remainingSeconds(t, now)),
            );
            const dismiss = document.createElement("button");
            dismiss.type = "button";
            dismiss.setAttribute("aria-label", `Arrêter le timer ${t.name}`);
            dismiss.textContent = "✕";
            dismiss.addEventListener("click", () => {
              writeTimers(removeTimer(readTimers(), t.id));
              notified.delete(t.id);
              render();
            });
            li.append(name, rem, dismiss);
            return li;
          }),
        );
      }

      document
        .querySelectorAll<HTMLElement>(".step-timer[data-seconds]")
        .forEach((el) => {
          el.addEventListener("click", () => {
            const id = el.dataset.timerId;
            const name = el.dataset.timerName ?? "Timer";
            const duration = Number(el.dataset.seconds);
            if (!id || !Number.isFinite(duration) || duration <= 0) return;
            writeTimers(
              addTimer(readTimers(), {
                id,
                name,
                durationSeconds: duration,
                startedAt: Date.now(),
              }),
            );
            render();
          });
        });

      setInterval(render, 1000);
      render();
    </script>

    <script>
      const root = document.documentElement;
      const btn = document.getElementById("theme-toggle");

      function currentTheme(): "light" | "dark" {
        if (root.dataset.theme === "dark" || root.dataset.theme === "light") {
          return root.dataset.theme;
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      }

      btn?.addEventListener("click", () => {
        const next = currentTheme() === "dark" ? "light" : "dark";
        root.dataset.theme = next;
        try {
          localStorage.setItem("theme", next);
        } catch {}
      });
    </script>
  </body>
</html>
