---
import Base from "../layouts/Base.astro";
import { formatQty, formatUnit, pluralizeName } from "../lib/format";
import { withBase } from "../lib/url";

export async function getStaticPaths() {
  const modules = import.meta.glob("../generated/recipes/*.json", {
    eager: true,
  });
  return Object.entries(modules).map(([filePath, mod]) => {
    const slug = filePath.match(/\/([^/]+)\.json$/)![1];
    return {
      params: { slug },
      props: { recipe: (mod as { default: any }).default },
    };
  });
}

const { recipe } = Astro.props;
const meta = recipe.metadata as Record<string, string>;

// Pre-compute continuous step numbering across sections.
const sectionsWithNumbers = recipe.sections.map(
  (section: any, sectionIdx: number) => {
    const before = recipe.sections
      .slice(0, sectionIdx)
      .reduce((acc: number, s: any) => acc + s.steps.length, 0);
    return { ...section, startNum: before + 1 };
  },
);

const cookwareSummary =
  recipe.cookware
    ?.map((c: any) => {
      const qty = Number(c.quantity);
      return qty > 1 ? `${qty} ${pluralizeName(qty, c.name)}` : c.name;
    })
    .join(", ") ?? "";

const totalTime =
  (parseInt(meta["prep time"] ?? "0", 10) || 0) +
  (parseInt(meta["cook time"] ?? "0", 10) || 0);
---

<Base title={meta.title}>
  <main class="shell">
    <a href={withBase(import.meta.env.BASE_URL, "/")} class="back-link">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
      Mes recettes
    </a>

    <header class="recipe-header">
      <div>
        <p class="eyebrow">
          {meta.cuisine}{meta.region ? ` · ${meta.region}` : ""}
        </p>
        <h1>{meta.title}</h1>
        <div class="meta-row">
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            {meta["prep time"]}
            {meta["cook time"] && ` + ${meta["cook time"]}`}
          </span>
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
            </svg>
            {meta.servings} personnes
          </span>
          <span>Difficulté {meta.difficulty}</span>
        </div>
      </div>
      <a class="cta-cuisson" href={withBase(import.meta.env.BASE_URL, `cuisson/${Astro.params.slug}`)}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
          <polygon points="5 3 19 12 5 21 5 3" />
        </svg>
        Mode cuisson
      </a>
    </header>

    <div class="layout">
      <aside class="sidebar">
        <div class="hero-thumb">
          {meta.image ? (
            <img
              src={withBase(import.meta.env.BASE_URL, `images/${Astro.params.slug}.webp`)}
              alt={meta.title}
            />
          ) : (
            <svg width="80" height="80" viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 16 L30 16 Q29 27 17 28 Q5 27 4 16 Z" />
              <path d="M12 12 Q13 9 12 6" opacity="0.5" />
              <path d="M17 11 Q18 8 17 4" opacity="0.5" />
              <path d="M22 12 Q23 9 22 6" opacity="0.5" />
            </svg>
          )}
        </div>

        <div class="portions" data-original-servings={meta.servings}>
          <span class="muted">Portions</span>
          <div class="controls">
            <button type="button" aria-label="Diminuer">−</button>
            <span class="value" id="portions-value">{meta.servings}</span>
            <button type="button" aria-label="Augmenter">+</button>
          </div>
        </div>

        <p class="section-label">Ingrédients</p>
        <ul class="ingredient-list">
          {recipe.ingredients.map((ing: any) => {
            const hasNumericQty = typeof ing.quantity === "number";
            const qty = formatQty(ing.quantity, ing.unit);
            return (
              <li>
                <div class="check" aria-hidden="true"></div>
                <span class="name">{ing.name}</span>
                {qty ? (
                  <span
                    class="qty"
                    data-qty={hasNumericQty ? ing.quantity : undefined}
                    data-unit={hasNumericQty ? ing.unit : undefined}
                  >
                    {qty}
                  </span>
                ) : (
                  <span class="qty is-muted">au goût</span>
                )}
              </li>
            );
          })}
        </ul>

        {cookwareSummary && (
          <>
            <p class="section-label">Ustensiles</p>
            <p class="cookware-list">{cookwareSummary}</p>
          </>
        )}
      </aside>

      <section>
        {sectionsWithNumbers.map((section: any) => (
          <div>
            <h2 class="section-heading">{section.name}</h2>
            {section.steps.map((step: any, i: number) => (
              <div class="step">
                <div class="step-num">{section.startNum + i}</div>
                <p class="step-text">
                  {step.tokens.map((tok: any) => {
                    if (tok.type === "text") return tok.text;
                    if (tok.type === "ingredient") return tok.ingredient.name;
                    if (tok.type === "cookware") return tok.cookware.name;
                    if (tok.type === "timer") {
                      return (
                        <span class="step-timer">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                          </svg>
                          {tok.timer.quantity} {formatUnit(tok.timer.quantity, tok.timer.unit)}
                        </span>
                      );
                    }
                    return null;
                  })}
                </p>
              </div>
            ))}
          </div>
        ))}

        {recipe.tips.length > 0 && (
          <div class="tips">
            <h2>Astuces</h2>
            {recipe.tips.map((tip: string) => (
              <p>{tip}</p>
            ))}
          </div>
        )}
      </section>
    </div>
  </main>
</Base>

<script>
  import { formatQty } from "../lib/format";
  import { scaleQuantity } from "../lib/scale";

  const portions = document.querySelector<HTMLElement>(".portions");
  const valueEl = document.getElementById("portions-value");
  const minusBtn = portions?.querySelector<HTMLButtonElement>(
    'button[aria-label="Diminuer"]',
  );
  const plusBtn = portions?.querySelector<HTMLButtonElement>(
    'button[aria-label="Augmenter"]',
  );
  const original = Number(portions?.dataset.originalServings ?? "1");
  let current = original;

  function render() {
    if (valueEl) valueEl.textContent = String(current);
    const ratio = current / original;
    document.querySelectorAll<HTMLElement>(".qty[data-qty]").forEach((el) => {
      const base = Number(el.dataset.qty);
      const unit = el.dataset.unit;
      const scaled = scaleQuantity(base, ratio);
      el.textContent = formatQty(scaled, unit) ?? String(scaled);
    });
  }

  plusBtn?.addEventListener("click", () => {
    current += 1;
    render();
  });
  minusBtn?.addEventListener("click", () => {
    if (current > 1) {
      current -= 1;
      render();
    }
  });
</script>
