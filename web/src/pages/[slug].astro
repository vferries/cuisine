---
import Base from "../layouts/Base.astro";
import { timerSeconds } from "../lib/cuisson";
import { formatQty, formatUnit, pluralizeName } from "../lib/format";
import { withBase } from "../lib/url";

export async function getStaticPaths() {
  const modules = import.meta.glob("../generated/recipes/*.json", {
    eager: true,
  });
  return Object.entries(modules).map(([filePath, mod]) => {
    const slug = filePath.match(/\/([^/]+)\.json$/)![1];
    return {
      params: { slug },
      props: { recipe: (mod as { default: any }).default },
    };
  });
}

const { recipe } = Astro.props;
const meta = recipe.metadata as Record<string, string>;

// Pre-compute continuous step numbering across sections.
const sectionsWithNumbers = recipe.sections.map(
  (section: any, sectionIdx: number) => {
    const before = recipe.sections
      .slice(0, sectionIdx)
      .reduce((acc: number, s: any) => acc + s.steps.length, 0);
    return { ...section, startNum: before + 1 };
  },
);

const cookwareSummary =
  recipe.cookware
    ?.map((c: any) => {
      const qty = Number(c.quantity);
      return qty > 1 ? `${qty} ${pluralizeName(qty, c.name)}` : c.name;
    })
    .join(", ") ?? "";

const totalTime =
  (parseInt(meta["prep time"] ?? "0", 10) || 0) +
  (parseInt(meta["cook time"] ?? "0", 10) || 0);
---

<Base title={meta.title}>
  <main class="shell">
    <a href={withBase(import.meta.env.BASE_URL, "/")} class="back-link">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
      Mes recettes
    </a>

    <header class="recipe-header">
      <div>
        <p class="eyebrow">
          {meta.cuisine}{meta.region ? ` · ${meta.region}` : ""}
        </p>
        <h1>{meta.title}</h1>
        <div class="meta-row">
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            {meta["prep time"]}
            {meta["cook time"] && ` + ${meta["cook time"]}`}
          </span>
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
            </svg>
            {meta.servings} personnes
          </span>
          <span>Difficulté {meta.difficulty}</span>
        </div>
      </div>
      <div class="header-actions">
        <button
          type="button"
          class="favorite-toggle"
          aria-pressed="false"
          aria-label="Marquer comme favori"
          data-slug={Astro.params.slug}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
          </svg>
        </button>
        <button
          type="button"
          class="share-btn"
          data-share-title={meta.title}
          aria-label="Partager la recette"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="18" cy="5" r="3" />
            <circle cx="6" cy="12" r="3" />
            <circle cx="18" cy="19" r="3" />
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
          </svg>
          <span class="share-label">Partager</span>
        </button>
        <a class="cta-cuisson" href={withBase(import.meta.env.BASE_URL, `cuisson/${Astro.params.slug}`)}>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          Mode cuisson
        </a>
      </div>
    </header>

    <nav class="tabs" role="tablist" aria-label="Sections de la recette">
      <button role="tab" type="button" aria-selected="true" data-panel="ingredients">Ingrédients</button>
      <button role="tab" type="button" aria-selected="false" data-panel="steps">Étapes</button>
      <button role="tab" type="button" aria-selected="false" data-panel="cookware">Ustensiles</button>
    </nav>

    <div class="layout" data-active-panel="ingredients">
      <aside class="sidebar">
        <div class="hero-thumb">
          {meta.image ? (
            <img
              src={withBase(import.meta.env.BASE_URL, `images/${Astro.params.slug}.webp`)}
              alt={meta.title}
            />
          ) : (
            <svg width="80" height="80" viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 16 L30 16 Q29 27 17 28 Q5 27 4 16 Z" />
              <path d="M12 12 Q13 9 12 6" opacity="0.5" />
              <path d="M17 11 Q18 8 17 4" opacity="0.5" />
              <path d="M22 12 Q23 9 22 6" opacity="0.5" />
            </svg>
          )}
        </div>

        <div class="portions" data-original-servings={meta.servings}>
          <span class="muted">Portions</span>
          <div class="controls">
            <button type="button" aria-label="Diminuer">−</button>
            <span class="value" id="portions-value">{meta.servings}</span>
            <button type="button" aria-label="Augmenter">+</button>
          </div>
        </div>

        <div class="panel" data-panel="ingredients">
          <div class="panel-header">
            <p class="section-label">Ingrédients</p>
            <button type="button" class="checklist-clear">Tout décocher</button>
          </div>
          <ul class="ingredient-list" data-slug={Astro.params.slug}>
            {recipe.ingredients.map((ing: any) => {
              const hasNumericQty = typeof ing.quantity === "number";
              const qty = formatQty(ing.quantity, ing.unit);
              return (
                <li data-ingredient={ing.name}>
                  <div class="check" aria-hidden="true"></div>
                  <span class="name">{ing.name}</span>
                  {qty ? (
                    <span
                      class="qty"
                      data-qty={hasNumericQty ? ing.quantity : undefined}
                      data-unit={hasNumericQty ? ing.unit : undefined}
                    >
                      {qty}
                    </span>
                  ) : (
                    <span class="qty is-muted">au goût</span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>

        {cookwareSummary && (
          <div class="panel" data-panel="cookware">
            <p class="section-label">Ustensiles</p>
            <p class="cookware-list">{cookwareSummary}</p>
          </div>
        )}
      </aside>

      <section class="panel" data-panel="steps">
        {sectionsWithNumbers.map((section: any, sectionIdx: number) => (
          <div>
            <h2 class="section-heading">{section.name}</h2>
            {section.steps.map((step: any, i: number) => (
              <div class="step">
                <div class="step-num">{section.startNum + i}</div>
                <p class="step-text">
                  {step.tokens.map((tok: any, tokIdx: number) => {
                    if (tok.type === "text") return tok.text;
                    if (tok.type === "ingredient") return tok.ingredient.name;
                    if (tok.type === "cookware") return tok.cookware.name;
                    if (tok.type === "timer") {
                      const seconds = timerSeconds(tok.timer);
                      const timerId = `${Astro.params.slug}:${sectionIdx}:${i}:${tokIdx}`;
                      const name = tok.timer.name || section.name;
                      return (
                        <span
                          class="step-timer"
                          data-seconds={seconds}
                          data-timer-id={timerId}
                          data-timer-name={name}
                        >
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                          </svg>
                          {tok.timer.quantity} {formatUnit(tok.timer.quantity, tok.timer.unit)}
                        </span>
                      );
                    }
                    return null;
                  })}
                </p>
              </div>
            ))}
          </div>
        ))}

        {recipe.tips.length > 0 && (
          <div class="tips">
            <h2>Astuces</h2>
            {recipe.tips.map((tip: string) => (
              <p>{tip}</p>
            ))}
          </div>
        )}
      </section>
    </div>
  </main>
</Base>

<script>
  import { formatQty } from "../lib/format";
  import { scaleQuantity } from "../lib/scale";
  import {
    isFavorite,
    readFavorites,
    toggleFavorite,
    writeFavorites,
  } from "../lib/favorites";
  import { shareRecipe } from "../lib/share";

  const shareBtn = document.querySelector<HTMLButtonElement>(".share-btn");
  if (shareBtn) {
    const label = shareBtn.querySelector<HTMLElement>(".share-label");
    const title = shareBtn.dataset.shareTitle ?? document.title;
    shareBtn.addEventListener("click", async () => {
      const result = await shareRecipe(
        { title, url: window.location.href },
        {
          share: typeof navigator.share === "function"
            ? (data) => navigator.share!(data)
            : undefined,
          copy: (t) => navigator.clipboard.writeText(t),
        },
      );
      if (result === "copied" && label) {
        const previous = label.textContent ?? "Partager";
        label.textContent = "Lien copié";
        setTimeout(() => {
          label.textContent = previous;
        }, 2000);
      }
    });
  }

  const favoriteBtn = document.querySelector<HTMLButtonElement>(
    ".favorite-toggle[data-slug]",
  );
  if (favoriteBtn) {
    const slug = favoriteBtn.dataset.slug!;
    const sync = () => {
      const favs = readFavorites(localStorage);
      favoriteBtn.setAttribute(
        "aria-pressed",
        isFavorite(favs, slug) ? "true" : "false",
      );
    };
    sync();
    favoriteBtn.addEventListener("click", () => {
      const next = toggleFavorite(readFavorites(localStorage), slug);
      writeFavorites(localStorage, next);
      sync();
    });
  }

  const portions = document.querySelector<HTMLElement>(".portions");
  const valueEl = document.getElementById("portions-value");
  const minusBtn = portions?.querySelector<HTMLButtonElement>(
    'button[aria-label="Diminuer"]',
  );
  const plusBtn = portions?.querySelector<HTMLButtonElement>(
    'button[aria-label="Augmenter"]',
  );
  const original = Number(portions?.dataset.originalServings ?? "1");
  let current = original;

  function render() {
    if (valueEl) valueEl.textContent = String(current);
    const ratio = current / original;
    document.querySelectorAll<HTMLElement>(".qty[data-qty]").forEach((el) => {
      const base = Number(el.dataset.qty);
      const unit = el.dataset.unit;
      const scaled = scaleQuantity(base, ratio);
      el.textContent = formatQty(scaled, unit) ?? String(scaled);
    });
  }

  plusBtn?.addEventListener("click", () => {
    current += 1;
    render();
  });
  minusBtn?.addEventListener("click", () => {
    if (current > 1) {
      current -= 1;
      render();
    }
  });

  const ingredientList = document.querySelector<HTMLElement>(".ingredient-list");
  const clearBtn = document.querySelector<HTMLButtonElement>(".checklist-clear");
  if (ingredientList) {
    const slug = ingredientList.dataset.slug ?? "";
    const storageKey = `ingredients-checked:${slug}`;
    const readChecked = (): Set<string> => {
      try {
        return new Set(JSON.parse(localStorage.getItem(storageKey) ?? "[]"));
      } catch {
        return new Set();
      }
    };
    const writeChecked = (set: Set<string>) => {
      localStorage.setItem(storageKey, JSON.stringify([...set]));
    };

    const checked = readChecked();
    const items = ingredientList.querySelectorAll<HTMLElement>("li[data-ingredient]");
    items.forEach((li) => {
      if (checked.has(li.dataset.ingredient!)) {
        li.classList.add("is-checked");
      }
      li.addEventListener("click", () => {
        const name = li.dataset.ingredient!;
        if (checked.has(name)) {
          checked.delete(name);
          li.classList.remove("is-checked");
        } else {
          checked.add(name);
          li.classList.add("is-checked");
        }
        writeChecked(checked);
      });
    });

    clearBtn?.addEventListener("click", () => {
      checked.clear();
      writeChecked(checked);
      items.forEach((li) => li.classList.remove("is-checked"));
    });
  }

  const tabs = document.querySelectorAll<HTMLButtonElement>(
    '.tabs [role="tab"]',
  );
  const layout = document.querySelector<HTMLElement>(".layout");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => t.setAttribute("aria-selected", "false"));
      tab.setAttribute("aria-selected", "true");
      if (layout && tab.dataset.panel) {
        layout.setAttribute("data-active-panel", tab.dataset.panel);
      }
    });
  });
</script>
