---
import Base from "../layouts/Base.astro";
import indexData from "../generated/index.json";
import { withBase } from "../lib/url";

interface RecipeMeta {
  slug: string;
  title: string;
  servings: number;
  prepTime: number;
  cookTime: number;
  totalTime: number;
  difficulty: string;
  cuisine: string;
  tags: string[];
  image?: string;
}

const recipes: RecipeMeta[] = indexData.recipes;

const cuisineToThumb: Record<string, string> = {
  vietnamienne: "is-coral",
  thaï: "is-coral",
  chinoise: "is-coral",
  italienne: "is-amber",
  française: "is-pink",
  japonaise: "is-gray",
};
const thumbClass = (c: string) => cuisineToThumb[c?.toLowerCase()] ?? "is-gray";
---

<Base title="Mes recettes">
  <main class="shell">
    <header class="home-header">
      <p class="eyebrow">Cuisine</p>
      <h1>Mes recettes</h1>
    </header>

    <div class="search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input type="search" placeholder="Nom, ingrédient, tag…" aria-label="Rechercher une recette" />
    </div>

    <nav class="chips" aria-label="Filtres rapides">
      <button class="chip is-active" type="button" data-chip="all">Toutes</button>
      <button class="chip" type="button" data-chip="favoris">Favoris</button>
      <button class="chip" type="button" data-chip="rapide">Rapide</button>
      <button class="chip" type="button" data-chip="vege">Végé</button>
      <button class="chip" type="button" data-chip="asiatique">Asiatique</button>
      <button class="chip" type="button" data-chip="francais">Français</button>
      <button class="chip" type="button" data-chip="dessert">Dessert</button>
    </nav>

    <button
      class="advanced-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="advanced-panel"
    >
      Filtres avancés
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
    </button>

    <section
      id="advanced-panel"
      class="advanced-panel"
      aria-hidden="true"
    >
      <div class="advanced-panel__inner">
        <fieldset class="advanced-group">
          <legend>Recherche</legend>
          <div class="chips">
            <button class="chip is-active" type="button" data-scope="all">Tout</button>
            <button class="chip" type="button" data-scope="ingredients">Ingrédients</button>
          </div>
        </fieldset>
        <fieldset class="advanced-group">
          <legend>Course</legend>
          <div class="chips">
            <button class="chip" type="button" data-course="entrée">Entrée</button>
            <button class="chip" type="button" data-course="plat">Plat</button>
            <button class="chip" type="button" data-course="dessert">Dessert</button>
          </div>
        </fieldset>
        <fieldset class="advanced-group">
          <legend>Difficulté</legend>
          <div class="chips">
            <button class="chip" type="button" data-difficulty="facile">Facile</button>
            <button class="chip" type="button" data-difficulty="moyenne">Moyenne</button>
            <button class="chip" type="button" data-difficulty="difficile">Difficile</button>
          </div>
        </fieldset>
        <fieldset class="advanced-group">
          <legend>Régime</legend>
          <div class="chips">
            <button class="chip" type="button" data-diet="sans-gluten" aria-pressed="false">Sans gluten</button>
          </div>
        </fieldset>
        <fieldset class="advanced-group">
          <legend>Tri</legend>
          <div class="chips">
            <button class="chip is-active" type="button" data-sort="recent">Récent</button>
            <button class="chip" type="button" data-sort="alpha">Alphabétique</button>
            <button class="chip" type="button" data-sort="duration">Durée</button>
          </div>
        </fieldset>
      </div>
    </section>

    <div class="count-row">
      <span class="count">{recipes.length} recette{recipes.length > 1 ? "s" : ""}</span>
      <div class="count-row__actions">
        <button class="random-btn" type="button" aria-label="Choisir une recette au hasard">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <circle cx="8" cy="8" r="1.2" fill="currentColor" />
            <circle cx="16" cy="8" r="1.2" fill="currentColor" />
            <circle cx="12" cy="12" r="1.2" fill="currentColor" />
            <circle cx="8" cy="16" r="1.2" fill="currentColor" />
            <circle cx="16" cy="16" r="1.2" fill="currentColor" />
          </svg>
          Au hasard
        </button>
        <button class="sort" type="button" aria-controls="advanced-panel">
          <span class="sort-label">Récent</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
        </button>
      </div>
    </div>

    <ul class="recipe-list">
      {recipes.map((r) => (
        <li class="recipe-row" data-slug={r.slug}>
          <a href={withBase(import.meta.env.BASE_URL, r.slug)}>
            <div class={`thumb ${thumbClass(r.cuisine)}`}>
              {r.image ? (
                <img
                  src={withBase(import.meta.env.BASE_URL, `images/${r.slug}.thumb.webp`)}
                  alt={r.title}
                  loading="lazy"
                />
              ) : (
                <svg width="36" height="36" viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 16 L30 16 Q29 27 17 28 Q5 27 4 16 Z" />
                  <path d="M12 12 Q13 9 12 6" opacity="0.5" />
                  <path d="M17 11 Q18 8 17 4" opacity="0.5" />
                  <path d="M22 12 Q23 9 22 6" opacity="0.5" />
                </svg>
              )}
            </div>
            <div class="rec-content">
              <p class="rec-tag">{r.cuisine}</p>
              <h3 class="rec-title">{r.title}</h3>
              <p class="rec-meta">
                <span>{r.totalTime} min</span>
                <span class="dot"></span>
                <span>{r.servings} pers</span>
                <span class="dot"></span>
                <span>{r.difficulty}</span>
              </p>
            </div>
          </a>
          <button
            type="button"
            class="favorite-toggle is-card"
            aria-pressed="false"
            aria-label={`Marquer ${r.title} comme favori`}
            data-slug={r.slug}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
          </button>
        </li>
      ))}
    </ul>

    {recipes.length === 0 && (
      <p class="muted" style="padding: 40px 0; text-align: center;">
        Aucune recette pour l'instant. Ajoutes-en dans <code>recipes/</code> puis lance <code>pnpm build-index</code>.
      </p>
    )}
  </main>
</Base>

<script>
  import indexData from "../generated/index.json";
  import {
    matchingRecipeSlugs,
    type RecipeSearchDoc,
    type SearchScope,
  } from "../lib/search";
  import {
    filterByChip,
    filterByCourse,
    filterByDifficulty,
    filterBySansGluten,
    type ChipKey,
    type ChipFilterDoc,
    type Course,
    type Difficulty,
  } from "../lib/chips";
  import { sortRecipes, type SortMode, type SortableRecipe } from "../lib/sort";
  import {
    isFavorite,
    readFavorites,
    toggleFavorite,
    writeFavorites,
  } from "../lib/favorites";
  import { pickRandom } from "../lib/random";
  import { withBase } from "../lib/url";

  const recipes = indexData.recipes as RecipeSearchDoc[] &
    ChipFilterDoc[] &
    SortableRecipe[];
  const input = document.querySelector<HTMLInputElement>(
    'input[type="search"]',
  );
  const list = document.querySelector<HTMLUListElement>(".recipe-list");
  const chipButtons = document.querySelectorAll<HTMLButtonElement>(
    ".chip[data-chip]",
  );
  const courseChips = document.querySelectorAll<HTMLButtonElement>(
    ".chip[data-course]",
  );
  const difficultyChips = document.querySelectorAll<HTMLButtonElement>(
    ".chip[data-difficulty]",
  );
  const sansGlutenChip = document.querySelector<HTMLButtonElement>(
    '.chip[data-diet="sans-gluten"]',
  );
  const sortChips = document.querySelectorAll<HTMLButtonElement>(
    ".chip[data-sort]",
  );
  const scopeChips = document.querySelectorAll<HTMLButtonElement>(
    ".chip[data-scope]",
  );
  const sortLabel = document.querySelector<HTMLElement>(
    ".count-row .sort-label",
  );
  const advancedToggle = document.querySelector<HTMLButtonElement>(
    ".advanced-toggle",
  );
  const advancedPanel = document.querySelector<HTMLElement>(
    "#advanced-panel",
  );
  const favoriteButtons = document.querySelectorAll<HTMLButtonElement>(
    ".favorite-toggle.is-card[data-slug]",
  );

  if (input && list) {
    const rowBySlug = new Map<string, HTMLElement>();
    list
      .querySelectorAll<HTMLElement>(".recipe-row[data-slug]")
      .forEach((row) => {
        rowBySlug.set(row.dataset.slug!, row);
      });

    let currentQuery = "";
    let activeChip: ChipKey = "all";
    let activeCourse: Course | null = null;
    let activeDifficulty: Difficulty | null = null;
    let sansGlutenActive = false;
    let activeSort: SortMode = "recent";
    let activeScope: SearchScope = "all";

    const SORT_LABELS: Record<SortMode, string> = {
      recent: "Récent",
      alpha: "Alphabétique",
      duration: "Durée",
    };

    const syncHearts = () => {
      const favs = readFavorites(localStorage);
      favoriteButtons.forEach((btn) => {
        btn.setAttribute(
          "aria-pressed",
          isFavorite(favs, btn.dataset.slug!) ? "true" : "false",
        );
      });
    };

    function render() {
      const favorites = readFavorites(localStorage);
      const allowedByChip = new Set(
        filterByChip(recipes, activeChip, { favorites }),
      );
      const allowedByCourse = new Set(filterByCourse(recipes, activeCourse));
      const allowedByDifficulty = new Set(
        filterByDifficulty(recipes, activeDifficulty),
      );
      const allowedByDiet = new Set(
        filterBySansGluten(recipes, sansGlutenActive),
      );
      const matched = new Set(
        matchingRecipeSlugs(recipes, currentQuery, activeScope),
      );
      const order = sortRecipes(recipes, activeSort);
      const slugs = order.filter(
        (s) =>
          matched.has(s) &&
          allowedByChip.has(s) &&
          allowedByCourse.has(s) &&
          allowedByDifficulty.has(s) &&
          allowedByDiet.has(s),
      );
      list!.replaceChildren();
      for (const slug of slugs) {
        const row = rowBySlug.get(slug);
        if (row) list!.appendChild(row);
      }
    }

    input.addEventListener("input", (event) => {
      currentQuery = (event.target as HTMLInputElement).value;
      render();
    });

    chipButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeChip = btn.dataset.chip as ChipKey;
        chipButtons.forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        render();
      });
    });

    courseChips.forEach((btn) => {
      btn.addEventListener("click", () => {
        const next = btn.dataset.course as Course;
        if (activeCourse === next) {
          activeCourse = null;
          btn.classList.remove("is-active");
        } else {
          activeCourse = next;
          courseChips.forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
        }
        render();
      });
    });

    difficultyChips.forEach((btn) => {
      btn.addEventListener("click", () => {
        const next = btn.dataset.difficulty as Difficulty;
        if (activeDifficulty === next) {
          activeDifficulty = null;
          btn.classList.remove("is-active");
        } else {
          activeDifficulty = next;
          difficultyChips.forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");
        }
        render();
      });
    });

    sortChips.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeSort = btn.dataset.sort as SortMode;
        sortChips.forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        if (sortLabel) sortLabel.textContent = SORT_LABELS[activeSort];
        render();
      });
    });

    scopeChips.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeScope = btn.dataset.scope as SearchScope;
        scopeChips.forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        render();
      });
    });

    sansGlutenChip?.addEventListener("click", () => {
      sansGlutenActive = !sansGlutenActive;
      sansGlutenChip.classList.toggle("is-active", sansGlutenActive);
      sansGlutenChip.setAttribute("aria-pressed", String(sansGlutenActive));
      render();
    });

    const setPanelOpen = (open: boolean) => {
      if (!advancedToggle || !advancedPanel) return;
      advancedToggle.setAttribute("aria-expanded", String(open));
      advancedPanel.setAttribute("aria-hidden", String(!open));
    };
    if (advancedToggle && advancedPanel) {
      advancedToggle.addEventListener("click", () => {
        const open = advancedToggle.getAttribute("aria-expanded") !== "true";
        setPanelOpen(open);
      });
      const sortButton = document.querySelector<HTMLButtonElement>(
        ".count-row .sort",
      );
      sortButton?.addEventListener("click", () => setPanelOpen(true));
    }

    favoriteButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const slug = btn.dataset.slug!;
        const next = toggleFavorite(readFavorites(localStorage), slug);
        writeFavorites(localStorage, next);
        syncHearts();
        if (activeChip === "favoris") render();
      });
    });

    const randomBtn = document.querySelector<HTMLButtonElement>(".random-btn");
    randomBtn?.addEventListener("click", () => {
      const visibleSlugs = Array.from(
        list!.querySelectorAll<HTMLElement>(".recipe-row[data-slug]"),
      )
        .map((row) => row.dataset.slug)
        .filter((s): s is string => Boolean(s));
      const pick = pickRandom(visibleSlugs);
      if (pick) {
        window.location.href = withBase(import.meta.env.BASE_URL, pick);
      }
    });

    syncHearts();
  }
</script>
