{
  "name": "cuisine",
  "version": "0.1.0",
  "private": true,
  "description": "Recettes en Cooklang — site web + app Android",
  "scripts": {
    "build-index": "pnpm --filter @cuisine/tooling build-index",
    "validate": "pnpm --filter @cuisine/tooling validate",
    "dev": "pnpm build-index && pnpm --filter @cuisine/web dev",
    "build": "pnpm build-index && pnpm --filter @cuisine/web build",
    "preview": "pnpm --filter @cuisine/web preview",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm build-index && pnpm --filter @cuisine/web test:e2e"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "vitest": "^2"
  }
}
