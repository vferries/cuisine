{
  "name": "cuisine",
  "version": "0.1.0",
  "private": true,
  "description": "Recettes en Cooklang — site web + app Android",
  "scripts": {
    "build-index": "pnpm --filter @cuisine/tooling build-index",
    "dev": "pnpm build-index && pnpm --filter @cuisine/web dev",
    "build": "pnpm build-index && pnpm --filter @cuisine/web build",
    "preview": "pnpm --filter @cuisine/web preview"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0"
}
